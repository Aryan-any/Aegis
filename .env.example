# 🦉 SagePilot (Aegis) - Environment Configuration Template

# --- LLM API KEYS ---
# Required: Google Gemini API Key (https://aistudio.google.com/)
GOOGLE_API_KEY=your_gemini_api_key_here

# Required: OpenRouter API Key (https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- ORCHESTRATION ---
# Local Temporal Server Address (Default for local development)
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# --- PERSISTENCE ---
# Database connection string (SQLite is used by default for the POC)
# Ensure the path is correct for your local environment
DATABASE_URL=sqlite:///./sagepilot.db

# --- AGENT CONFIG ---
# Default model to use via OpenRouter
OPENROUTER_MODEL=minimax/minimax-m2.5:free

# --- SECURITY ---
# CORS Allowed Origins
ALLOWED_ORIGINS=*
